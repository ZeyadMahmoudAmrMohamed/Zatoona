# Team C
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Team B
LIGHTNING_API_KEY=your_lightning_key
LIGHTNING_BASE_URL=https://lightning.ai/api/v1/
MODEL_NAME=your_model_name
MAX_VALIDATION_ITERATIONS=3

# Team A
OPENAI_API_KEY=your_openai_key
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=student_notes
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000
RETRIEVAL_TOP_K=5
RETRIEVAL_MODE=hybrid
RERANK_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_MIN_SCORE=  # optional; cross-encoder scores are often negative — do not set to 0
SESSION_ID=default
SESSION_RESET_ON_START=true
DOCLING_OCR_ENGINE=rapidocr
DOCLING_DO_OCR=true
CHUNK_MODE=hybrid
CHUNK_MAX_TOKENS=512
ASR_PROVIDER=local
ASR_MODEL=base
VIDEO_ENABLED=false

# Postgres (Docker services override host/port via docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=mydb

# Shared flags
USE_REAL_MCP=false
USE_REAL_EXAM=false
USE_REAL_ANSWERS=false
UI_PORT=8501